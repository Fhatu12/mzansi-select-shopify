<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#111111">
    <link rel="canonical" href="{{ canonical_url }}">
    <title>
      {{ page_title }}
      {% if current_tags %}
        {%- assign meta_tags = current_tags | join: ', ' -%}
        &ndash; Tagged "{{ meta_tags }}"
      {% endif %}
      {% if current_page != 1 %}&ndash; Page {{ current_page }}{% endif %}
      {% unless page_title contains shop.name %}&ndash; {{ shop.name }}{% endunless %}
    </title>
    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet">
    {{ content_for_header }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <style>
      @media (max-width: 900px) {
        header.site-header-desktop,
        nav.site-nav-desktop,
        .footer-desktop {
          display: none !important;
        }

        header.mob-header,
        .footer-mobile {
          display: block !important;
        }

        nav.bottom-bar {
          display: flex !important;
        }

        .topbar {
          max-width: 100%;
          overflow: hidden;
        }

        .topbar-inner {
          width: 100%;
          max-width: 100%;
          min-width: 0;
        }

        .trust-inner,
        .trust-item {
          max-width: 100%;
          min-width: 0;
        }
      }
    </style>
  </head>
  <body class="{%- render 'preview-route-body-class' -%}">
    {% section 'announcement-topbar' %}
    {% section 'site-header' %}
    {% section 'primary-navigation' %}

    <main id="MainContent" class="page-shell" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'trust-bar' %}
    {% section 'site-footer' %}
    {% render 'toast-feedback' %}
    <script>
      (() => {
        const body = document.body;
        const menuToggle = document.getElementById('mobileMenuToggle');
        const drawer = document.getElementById('navDrawer');
        const overlay = document.getElementById('drawerOverlay');
        const drawerClose = document.getElementById('drawerClose');
        const searchInput = document.getElementById('mobileSearchInput');

        const setDrawerOpen = (open) => {
          if (!drawer || !overlay || !menuToggle) return;
          body.classList.toggle('mobile-nav-open', open);
          drawer.classList.toggle('open', open);
          overlay.classList.toggle('open', open);
          drawer.setAttribute('aria-hidden', String(!open));
          menuToggle.classList.toggle('open', open);
          menuToggle.setAttribute('aria-expanded', String(open));
        };

        const toggleDrawer = () => setDrawerOpen(!drawer?.classList.contains('open'));

        menuToggle?.addEventListener('click', toggleDrawer);
        overlay?.addEventListener('click', () => setDrawerOpen(false));
        drawerClose?.addEventListener('click', () => setDrawerOpen(false));
        drawer?.querySelectorAll('.mob-drawer-link').forEach((link) => {
          link.addEventListener('click', () => setDrawerOpen(false));
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') setDrawerOpen(false);
        });

        document.querySelectorAll('[data-mobile-search-trigger]').forEach((trigger) => {
          trigger.addEventListener('click', () => {
            if (!searchInput) return;
            searchInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
            searchInput.focus();
          });
        });

        const mobileMedia = window.matchMedia('(max-width: 900px)');
        const syncDrawerState = () => {
          if (!mobileMedia.matches) setDrawerOpen(false);
        };

        if (mobileMedia.addEventListener) {
          mobileMedia.addEventListener('change', syncDrawerState);
        } else if (mobileMedia.addListener) {
          mobileMedia.addListener(syncDrawerState);
        }
      })();
    </script>
  </body>
</html>
