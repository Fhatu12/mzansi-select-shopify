<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% assign gated_page_handles = 'about,contact' | split: ',' %}
    {% assign gated_support_page = false %}
    {% if request.page_type == 'page' and page != blank and gated_page_handles contains page.handle %}
      {% assign gated_support_page = true %}
    {% endif %}
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#111111">
    <link rel="canonical" href="{{ canonical_url }}">
    {% if gated_support_page %}
      <meta name="robots" content="noindex,nofollow">
    {% endif %}
    {% assign controlled_preview_route = false %}
    {% assign controlled_preview_route_path = '/collections/controlled-pilot' %}
    {% assign controlled_preview_pageurl = blank %}
    {% if request.path == controlled_preview_route_path or canonical_url contains controlled_preview_route_path %}
      {% assign controlled_preview_route = true %}
    {% elsif request.page_type == '404' and content_for_header contains '"pageurl":"' %}
      {% # theme-check-disable-next-line ContentForHeaderModification %}
      {% assign controlled_preview_pageurl = content_for_header | split: '"pageurl":"' | last | split: '"' | first | replace: '\\/', '/' | replace: '\\u0026', '&' %}
      {% if controlled_preview_pageurl contains controlled_preview_route_path %}
        {% assign controlled_preview_route = true %}
      {% endif %}
    {% endif %}
    <title>
      {% if controlled_preview_route %}
        Controlled pilot preview
      {% else %}
        {{ page_title }}
        {% if current_tags %}
          {%- assign meta_tags = current_tags | join: ', ' -%}
          &ndash; Tagged "{{ meta_tags }}"
        {% endif %}
        {% if current_page != 1 %}&ndash; Page {{ current_page }}{% endif %}
      {% endif %}
      {% unless page_title contains shop.name %}&ndash; {{ shop.name }}{% endunless %}
    </title>
    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}
    <script>
      (() => {
        const root = document.documentElement;
        const mobileShellMedia = window.matchMedia('(max-width: 900px)');
        const applyShellMode = (matches) => {
          root.dataset.shellMode = matches ? 'mobile' : 'desktop';
        };

        applyShellMode(mobileShellMedia.matches);

        if (mobileShellMedia.addEventListener) {
          mobileShellMedia.addEventListener('change', (event) => applyShellMode(event.matches));
        } else if (mobileShellMedia.addListener) {
          mobileShellMedia.addListener((event) => applyShellMode(event.matches));
        }
      })();
    </script>
    {{ content_for_header }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'wishlist-local.js' | asset_url }}" defer></script>
    {% if template.name == 'product' %}
      <script src="{{ 'product-gallery.js' | asset_url }}" defer></script>
      <script src="{{ 'product-options-preview.js' | asset_url }}" defer></script>
    {% endif %}
    <style>
      @font-face {
        font-family: 'DM Sans';
        font-style: normal;
        font-weight: 300;
        font-display: swap;
        src: url("{{ 'dm-sans-300.ttf' | asset_url }}") format('truetype');
      }

      @font-face {
        font-family: 'DM Sans';
        font-style: normal;
        font-weight: 400;
        font-display: swap;
        src: url("{{ 'dm-sans-400.ttf' | asset_url }}") format('truetype');
      }

      @font-face {
        font-family: 'DM Sans';
        font-style: normal;
        font-weight: 500;
        font-display: swap;
        src: url("{{ 'dm-sans-500.ttf' | asset_url }}") format('truetype');
      }

      @font-face {
        font-family: 'DM Sans';
        font-style: normal;
        font-weight: 600;
        font-display: swap;
        src: url("{{ 'dm-sans-600.ttf' | asset_url }}") format('truetype');
      }

      @font-face {
        font-family: 'DM Sans';
        font-style: normal;
        font-weight: 700;
        font-display: swap;
        src: url("{{ 'dm-sans-700.ttf' | asset_url }}") format('truetype');
      }

      @font-face {
        font-family: 'Playfair Display';
        font-style: italic;
        font-weight: 400;
        font-display: swap;
        src: url("{{ 'playfair-display-400-italic.ttf' | asset_url }}") format('truetype');
      }

      @font-face {
        font-family: 'Playfair Display';
        font-style: normal;
        font-weight: 400;
        font-display: swap;
        src: url("{{ 'playfair-display-400.ttf' | asset_url }}") format('truetype');
      }

      @font-face {
        font-family: 'Playfair Display';
        font-style: normal;
        font-weight: 600;
        font-display: swap;
        src: url("{{ 'playfair-display-600.ttf' | asset_url }}") format('truetype');
      }

      @media (max-width: 900px) {
        html[data-shell-mode="mobile"] [data-shell="desktop-header"],
        html[data-shell-mode="mobile"] [data-shell="desktop-nav"],
        html[data-shell-mode="mobile"] [data-shell="desktop-footer"] {
          display: none !important;
        }

        html[data-shell-mode="mobile"] [data-shell="mobile-header"],
        html[data-shell-mode="mobile"] [data-shell="mobile-footer"] {
          display: block !important;
        }

        html[data-shell-mode="mobile"] [data-shell="mobile-nav"],
        html[data-shell-mode="mobile"] [data-shell="mobile-drawer"] {
          display: flex !important;
        }

        html[data-shell-mode="mobile"] [data-shell="mobile-overlay"] {
          display: block !important;
        }

        html[data-shell-mode="desktop"] [data-shell="mobile-header"],
        html[data-shell-mode="desktop"] [data-shell="mobile-nav"],
        html[data-shell-mode="desktop"] [data-shell="mobile-drawer"],
        html[data-shell-mode="desktop"] [data-shell="mobile-overlay"],
        html[data-shell-mode="desktop"] [data-shell="mobile-footer"] {
          display: none !important;
        }

        .topbar {
          max-width: 100%;
          overflow: hidden;
        }

        .topbar-inner {
          width: 100%;
          max-width: 100%;
          min-width: 0;
        }

        .trust-inner,
        .trust-item {
          max-width: 100%;
          min-width: 0;
        }
      }
    </style>
  </head>
  <body class="{%- render 'preview-route-body-class' -%}">
    <a class="skip-to-main" href="#MainContent">Skip to main content</a>
    {% section 'announcement-topbar' %}
    {% section 'site-header' %}
    {% section 'primary-navigation' %}

    <main id="MainContent" class="page-shell" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'trust-bar' %}
    {% section 'site-footer' %}
    <button type="button" class="back-to-top" id="backToTop" hidden aria-label="Back to top">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 19V5"></path>
        <path d="M5 12l7-7 7 7"></path>
      </svg>
    </button>
    {% render 'toast-feedback' %}
    <script>
      (() => {
        const body = document.body;
        const menuToggle = document.getElementById('mobileMenuToggle');
        const drawer = document.getElementById('navDrawer');
        const overlay = document.getElementById('drawerOverlay');
        const drawerClose = document.getElementById('drawerClose');
        const searchInput = document.getElementById('mobileSearchInput');
        const focusableSelector = 'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), summary, [tabindex]:not([tabindex="-1"])';
        let lastFocusedElement = null;

        const getDrawerFocusable = () => {
          if (!drawer) return [];
          return [...drawer.querySelectorAll(focusableSelector)].filter((element) => !element.hasAttribute('disabled'));
        };

        const focusFirstDrawerElement = () => {
          const [firstFocusable] = getDrawerFocusable();
          firstFocusable?.focus();
        };

        const setDrawerOpen = (open, { restoreFocus = true } = {}) => {
          if (!drawer || !overlay || !menuToggle) return;
          if (open) {
            lastFocusedElement = document.activeElement;
          }
          body.classList.toggle('mobile-nav-open', open);
          drawer.classList.toggle('open', open);
          overlay.classList.toggle('open', open);
          drawer.setAttribute('aria-hidden', String(!open));
          menuToggle.classList.toggle('open', open);
          menuToggle.setAttribute('aria-expanded', String(open));
          if (open) {
            window.setTimeout(focusFirstDrawerElement, 0);
          } else if (restoreFocus && lastFocusedElement && typeof lastFocusedElement.focus === 'function') {
            lastFocusedElement.focus();
          }
        };

        const toggleDrawer = () => setDrawerOpen(!drawer?.classList.contains('open'));

        menuToggle?.addEventListener('click', toggleDrawer);
        overlay?.addEventListener('click', () => setDrawerOpen(false));
        drawerClose?.addEventListener('click', () => setDrawerOpen(false));
        drawer?.querySelectorAll('.mob-drawer-link').forEach((link) => {
          link.addEventListener('click', () => setDrawerOpen(false));
        });

        document.addEventListener('keydown', (event) => {
          if (!drawer?.classList.contains('open')) return;
          if (event.key === 'Escape') {
            setDrawerOpen(false);
            return;
          }
          if (event.key !== 'Tab') return;

          const focusableElements = getDrawerFocusable();
          if (focusableElements.length === 0) return;

          const firstFocusable = focusableElements[0];
          const lastFocusable = focusableElements[focusableElements.length - 1];

          if (event.shiftKey && document.activeElement === firstFocusable) {
            event.preventDefault();
            lastFocusable.focus();
          } else if (!event.shiftKey && document.activeElement === lastFocusable) {
            event.preventDefault();
            firstFocusable.focus();
          }
        });

        document.querySelectorAll('[data-mobile-search-trigger]').forEach((trigger) => {
          trigger.addEventListener('click', () => {
            if (!searchInput) return;
            searchInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
            searchInput.focus();
          });
        });

        const mobileMedia = window.matchMedia('(max-width: 900px)');
        const syncDrawerState = () => {
          if (!mobileMedia.matches) setDrawerOpen(false, { restoreFocus: false });
        };

        if (mobileMedia.addEventListener) {
          mobileMedia.addEventListener('change', syncDrawerState);
        } else if (mobileMedia.addListener) {
          mobileMedia.addListener(syncDrawerState);
        }
      })();

      (() => {
        const backToTop = document.getElementById('backToTop');
        const main = document.getElementById('MainContent');
        if (!backToTop || !main) return;

        const showAfter = 400;
        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

        const syncVisibility = () => {
          const show = window.scrollY > showAfter;
          backToTop.hidden = !show;
          backToTop.classList.toggle('is-visible', show);
        };

        backToTop.addEventListener('click', () => {
          window.scrollTo({
            top: 0,
            behavior: reducedMotion.matches ? 'auto' : 'smooth'
          });
          main.focus({ preventScroll: true });
        });

        window.addEventListener('scroll', syncVisibility, { passive: true });
        syncVisibility();
      })();
    </script>
  </body>
</html>
