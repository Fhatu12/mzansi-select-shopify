<header>
  <div class="header-inner">
    <a class="logo" href="{{ routes.root_url }}">
      <div class="logo-top">Mzansi <em>Select</em></div>
      <div class="logo-tag">{{ settings.brand_tagline }}</div>
    </a>

    <form class="search-wrap" action="{{ routes.search_url }}" method="get" role="search">
      <input
        class="search-input"
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ settings.search_placeholder | escape }}"
      >
      <select class="search-cat" name="type">
        <option value="product">All categories</option>
        <option value="product">Home &amp; Living</option>
        <option value="product">Kitchen &amp; Storage</option>
        <option value="product">Office &amp; Desk</option>
        <option value="product">Tech Accessories</option>
      </select>
      <button class="search-btn" type="submit" aria-label="Search">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>
    </form>

    <div class="hdr-actions">
      <a class="hdr-action" href="{{ routes.account_url }}">
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
        Account
      </a>
      <a class="hdr-action" href="#wishlist" aria-disabled="true">
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
        </svg>
        Wishlist
      </a>
      <a class="hdr-action" href="{{ routes.cart_url }}">
        <span class="cart-dot">{{ cart.item_count }}</span>
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
        Cart
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Site header",
  "settings": []
}
{% endschema %}
