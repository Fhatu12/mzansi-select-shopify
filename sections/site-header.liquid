<header class="site-header-desktop" data-shell="desktop-header">
  <div class="header-inner">
    <a class="logo" href="{{ routes.root_url }}">
      <div class="logo-top">Mzansi <em>Select</em></div>
      <div class="logo-tag">{{ settings.brand_tagline }}</div>
    </a>

    <form class="search-wrap" action="{{ routes.search_url }}" method="get" role="search" aria-label="Site search">
      <label class="visually-hidden" for="desktopSearchInput">Search products</label>
      <input
        class="search-input"
        id="desktopSearchInput"
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ settings.search_placeholder | escape }}"
        autocomplete="off"
      >
      <label class="visually-hidden" for="desktopSearchType">Category filter</label>
      <input type="hidden" name="type" value="product">
      <select class="search-cat search-cat--deferred" id="desktopSearchType" disabled aria-disabled="true" aria-describedby="desktopSearchTypeNote">
        <option>All categories</option>
        <option>Home &amp; Living</option>
        <option>Kitchen &amp; Storage</option>
        <option>Office &amp; Desk</option>
        <option>Tech Accessories</option>
        <option>Retro Vault</option>
        <option>Games &amp; Toys</option>
      </select>
      <span class="visually-hidden" id="desktopSearchTypeNote">Category filter is visual-only for now. Search currently runs across all visible products.</span>
      <button class="search-btn" type="submit" aria-label="Search">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>
    </form>

    <div class="hdr-actions">
      <span class="hdr-action hdr-action--deferred" aria-disabled="true" aria-label="Account access is not active yet. Customer account features are coming later.">
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
        Account
      </span>
      <button class="hdr-action" type="button" data-wishlist-open data-wishlist-header-state aria-expanded="false" aria-controls="wishlistDrawer" aria-label="Open saved items drawer">
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
        </svg>
        Wishlist <span class="wishlist-count-badge" data-wishlist-count>0</span>
      </button>
      <a class="hdr-action" href="{{ routes.cart_url }}" aria-label="Open cart">
        <span class="cart-dot" id="cart-count">{{ cart.item_count }}</span>
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
        Cart
      </a>
    </div>
  </div>
</header>

<header class="mob-header" data-shell="mobile-header">
  <div class="mob-header-top">
    <button class="mob-menu-btn" type="button" id="mobileMenuToggle" aria-controls="navDrawer" aria-expanded="false" aria-label="Open menu">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <a class="mob-logo" href="{{ routes.root_url }}">
      <div class="mob-logo-top">Mzansi <em>Select</em></div>
      <div class="mob-logo-sub">{{ settings.brand_tagline }}</div>
    </a>

    <div class="mob-header-icons">
      <button class="mob-icon-btn" type="button" data-wishlist-open data-wishlist-header-state aria-expanded="false" aria-controls="wishlistDrawer" aria-label="Open saved items drawer">
        <span class="wishlist-count-badge wishlist-count-badge--mobile" data-wishlist-count>0</span>
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
        </svg>
      </button>
      <a class="mob-icon-btn" href="{{ routes.cart_url }}" aria-label="Open cart">
        <span class="cart-badge-mob">{{ cart.item_count }}</span>
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
      </a>
    </div>
  </div>

  <form class="mob-search-bar" action="{{ routes.search_url }}" method="get" role="search" aria-label="Mobile site search">
    <div class="mob-search-inner">
      <label class="visually-hidden" for="mobileSearchInput">Search products</label>
      <input
        class="mob-search-input"
        id="mobileSearchInput"
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ settings.search_placeholder | escape }}"
        autocomplete="off"
      >
      <input type="hidden" name="type" value="product">
      <button class="mob-search-btn" type="submit" aria-label="Search">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>
    </div>
  </form>
</header>

{% schema %}
{
  "name": "Site header",
  "settings": []
}
{% endschema %}
