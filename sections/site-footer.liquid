{% liquid
  assign preview_selected_picks_url = routes.root_url | append: '#best-sellers'
  assign preview_latest_url = routes.root_url | append: '#new-in'
  assign preview_picks_url = routes.root_url | append: '#deals'
  assign about_page_url = '/pages/about'
  assign contact_page_url = '/pages/contact#contact'
%}

<footer>
  <div class="footer-desktop" data-shell="desktop-footer">
    <div class="footer-inner">
      <div>
        <div class="f-logo-row">Mzansi <em>Select</em></div>
	        <div class="f-logo-tag">{{ settings.brand_tagline }}</div>
	        {% if settings.controlled_pilot_trust_mode %}
	          <p class="f-desc f-desc-default">Invite-only controlled pilot — not a public launch. A narrow Gadgetgyz-focused pilot range; not a full catalogue.</p>
	          <p class="f-desc f-desc-cautious">Hearts on product pages save items in this browser only. No account or checkout yet. Delivery, returns, and support details are not final until confirmed before launch or before any order fulfilment. Accounts and social links stay paused.</p>
	        {% else %}
	          <p class="f-desc f-desc-default">Preview catalogue for practical home and everyday essentials. Carefully chosen for South African shoppers.</p>
	          <p class="f-desc f-desc-cautious">Preview catalogue staging. Delivery coverage and fulfilment details are not final for preview items on this page.</p>
	        {% endif %}
        <div class="f-socials">
          <span class="f-social f-social--deferred" aria-disabled="true" aria-label="Social links coming later. Follow links paused during preview. Social profiles to be confirmed.">
            <svg width="13" height="13" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
          </span>
          <span class="f-social f-social--deferred" aria-disabled="true" aria-label="Social links coming later. Follow links paused during preview. Social profiles to be confirmed.">
