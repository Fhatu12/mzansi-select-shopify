        <ul class="f-links">
          <li><a href="{{ routes.all_products_collection_url }}">Shop All</a></li>
          <li><a href="{{ preview_latest_url }}">New In</a></li>
          <li><a href="{{ preview_selected_picks_url }}">Best Sellers</a></li>
          <li><a href="{{ preview_picks_url }}">Deals</a></li>
