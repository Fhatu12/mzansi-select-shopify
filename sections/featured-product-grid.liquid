{% liquid
  assign section_classes = 'section'
  if section.settings.background_style == 'cream'
    assign section_classes = section_classes | append: ' section-cream'
  endif
  assign section_classes = section_classes | append: ' section--product-rail'

  assign max_products = section.settings.max_products | default: 4
  if section.settings.collection_handle != blank
    assign rail_collection = collections[section.settings.collection_handle]
  elsif section.settings.content_preset == 'kitchen_storage'
    assign rail_collection = collections['kitchen-storage']
  else
    assign rail_collection = collections.all
  endif
%}

{% if rail_collection != blank and rail_collection.products_count > 0 %}
  <section id="{{ section.settings.anchor_id | escape }}" class="{{ section_classes }}">
    <div class="section-inner">
      {% render 'section-heading',
        title: section.settings.section_title,
        accent: section.settings.section_accent,
        link_label: section.settings.section_link_label,
        link_url: section.settings.section_link_url | default: routes.all_products_collection_url
      %}
      <div class="products-grid products-grid--live-rail products-grid--{{ section.settings.content_preset }}">
        {% for product in rail_collection.products limit: max_products %}
          {% render 'live-product-card',
            product: product,
            collection_context: rail_collection,
            cta_label: 'View product'
          %}
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Featured product grid",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "default": "curated-picks"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section title",
      "default": "Best"
    },
    {
      "type": "text",
      "id": "section_accent",
      "label": "Section accent",
      "default": "Sellers"
    },
    {
      "type": "text",
      "id": "section_link_label",
      "label": "Section link label",
      "default": "View all products"
    },
    {
      "type": "url",
      "id": "section_link_url",
      "label": "Section link URL"
    },
    {
      "type": "select",
      "id": "background_style",
      "label": "Background style",
      "default": "cream",
      "options": [
        {
          "value": "cream",
          "label": "Cream"
        },
        {
          "value": "white",
          "label": "White"
        }
      ]
    },
    {
      "type": "select",
      "id": "content_preset",
      "label": "Content preset",
      "default": "best_sellers",
      "options": [
        {
          "value": "best_sellers",
          "label": "Curated picks"
        },
        {
          "value": "kitchen_storage",
          "label": "Kitchen and storage"
        }
      ]
    },
    {
      "type": "text",
      "id": "collection_handle",
      "label": "Collection handle (optional override)",
      "info": "Defaults to all products for curated picks, or kitchen-storage for the kitchen preset."
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum products",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Featured product grid"
    }
  ]
}
{% endschema %}
