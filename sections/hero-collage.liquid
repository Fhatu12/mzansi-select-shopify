<section class="hero">
  <div class="hero-inner">
    <div class="hero-text">
      <div class="hero-badge">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        Shop with Confidence
      </div>
      <h1 class="hero-h1">Practical home and<br>everyday finds for<br><span class="gold">South African</span> shoppers</h1>
      <p class="hero-desc">Start with clear department-led browse paths, then move into curated picks with straightforward pricing and support.</p>
      <div class="hero-btns">
        <a class="btn-dark" href="{{ routes.all_products_collection_url }}">
          Browse all products
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
        <a class="btn-ghost" href="/policies/shipping-policy">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <rect x="1" y="3" width="15" height="13" rx="1"></rect>
            <path d="M16 8h5l2 5v4h-7V8z"></path>
            <circle cx="5.5" cy="18.5" r="2.5"></circle>
            <circle cx="18.5" cy="18.5" r="2.5"></circle>
          </svg>
          Shipping info
        </a>
      </div>
    </div>
    <div class="hero-visual">
      <div class="collage-grid">
        <div class="cg-item cg-wide">
          {% render 'decorative-image', asset: 'headphones-premium.jpg', alt: 'Decorative tech preview', width: 700, height: 520, loading: 'eager' %}
        </div>
        <div class="cg-item">
          {% render 'decorative-image', asset: 'smart-watch-black-edition.jpg', alt: 'Decorative accessories preview', width: 400, height: 400, loading: 'eager' %}
        </div>
        <div class="cg-item">
          {% render 'decorative-image', asset: 'insulated-vacuum-flask.jpg', alt: 'Decorative kitchen preview', width: 400, height: 400, loading: 'eager' %}
        </div>
        <div class="cg-item cg-tall">
          {% render 'decorative-image', asset: 'fabric-storage-cube.jpg', alt: 'Decorative storage preview', width: 400, height: 640, loading: 'eager' %}
        </div>
        <div class="cg-item">
          {% render 'decorative-image', asset: 'charger-accessory.jpg', alt: 'Decorative tech accessory preview', width: 400, height: 400, loading: 'eager' %}
        </div>
        <div class="cg-item">
          {% render 'decorative-image', asset: 'indoor-plant-pot.jpg', alt: 'Decorative home preview', width: 400, height: 400, loading: 'eager' %}
        </div>
        <div class="cg-item">
          {% render 'decorative-image', asset: 'touch-lamp-warm-led.jpg', alt: 'Decorative lighting preview', width: 400, height: 400, loading: 'eager' %}
        </div>
      </div>
      <div class="hero-badge-corner">
        <svg width="20" height="20" fill="none" stroke="#C8973A" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        Carefully chosen.<br>Fairly priced.
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero collage",
  "settings": [],
  "presets": [
    {
      "name": "Hero collage"
    }
  ]
}
{% endschema %}
