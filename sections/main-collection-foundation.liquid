{% assign live_collection_title = collection.title | default: section.settings.collection_title %}
{% assign live_collection_intro = collection.description | strip_html | strip %}
{% if live_collection_intro == blank %}
  {% assign live_collection_intro = section.settings.collection_intro %}
{% endif %}
{% assign has_live_collection_products = false %}
{% if collection != blank and collection.all_products_count > 0 %}
  {% assign has_live_collection_products = true %}
{% endif %}

<section class="collection-shell">
  <div class="section-inner">
    <div class="collection-hero">
      <div class="collection-kicker">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        {{ section.settings.collection_label }}
      </div>
      <h1 class="collection-title">
        {{ live_collection_title }}
        {% if collection == blank and section.settings.collection_accent != blank %}
          <span class="gold">{{ section.settings.collection_accent }}</span>
        {% endif %}
      </h1>
      <p class="collection-intro">{{ live_collection_intro }}</p>
    </div>

    <div class="collection-body">
      {% if has_live_collection_products == false %}
        <div class="collection-empty-wrap">
          {% render 'empty-state',
            badge: section.settings.empty_badge,
            title: collection.title | default: section.settings.empty_title,
            description: collection.description | strip_html | strip | default: section.settings.empty_description,
            action_label: section.settings.empty_action_label,
            action_url: routes.root_url
          %}
        </div>
      {% else %}
        {% render 'section-heading', title: section.settings.grid_heading %}
        <div class="products-grid">
          {% for product in collection.products %}
            {% render 'live-product-card', product: product, collection_context: collection %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection main",
  "settings": [
    {
      "type": "text",
      "id": "collection_label",
      "label": "Collection label",
      "default": "Browse by Category"
    },
    {
      "type": "text",
      "id": "collection_title",
      "label": "Collection title",
      "default": "Everyday"
    },
    {
      "type": "text",
      "id": "collection_accent",
      "label": "Collection title accent",
      "default": "Essentials"
    },
    {
      "type": "textarea",
      "id": "collection_intro",
      "label": "Collection intro",
      "default": "Explore a collection-led layout that follows the approved Mzansi Select grid rhythm, premium-practical typography, and straightforward browse flow while real catalogue wiring remains deferred."
    },
    {
      "type": "text",
      "id": "grid_heading",
      "label": "Grid heading",
      "default": "Featured in this category"
    },
    {
      "type": "select",
      "id": "view_state",
      "label": "View state",
      "default": "filled",
      "options": [
        {
          "value": "filled",
          "label": "Filled"
        },
        {
          "value": "empty",
          "label": "Empty"
        }
      ]
    },
    {
      "type": "text",
      "id": "empty_badge",
      "label": "Empty badge",
      "default": "Collection Preview"
    },
    {
      "type": "text",
      "id": "empty_title",
      "label": "Empty title",
      "default": "This category is being prepared"
    },
    {
      "type": "textarea",
      "id": "empty_description",
      "label": "Empty description",
      "default": "We have approved the collection layout foundation first. Real products and category-specific wiring will follow in a later approved slice."
    },
    {
      "type": "text",
      "id": "empty_action_label",
      "label": "Empty action label",
      "default": "Continue browsing"
    }
  ]
}
{% endschema %}
