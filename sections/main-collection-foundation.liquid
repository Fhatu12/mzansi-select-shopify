<section class="collection-shell">
  <div class="section-inner">
    <div class="collection-hero">
      <div class="collection-kicker">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        {{ section.settings.collection_label }}
      </div>
      <h1 class="collection-title">
        {{ section.settings.collection_title }}
        {% if section.settings.collection_accent != blank %}
          <span class="gold">{{ section.settings.collection_accent }}</span>
        {% endif %}
      </h1>
      <p class="collection-intro">{{ section.settings.collection_intro }}</p>
    </div>

    <div class="collection-body">
      {% if section.settings.view_state == 'empty' %}
        <div class="collection-empty-wrap">
          {% render 'empty-state',
            badge: section.settings.empty_badge,
            title: section.settings.empty_title,
            description: section.settings.empty_description,
            action_label: section.settings.empty_action_label,
            action_url: routes.root_url
          %}
        </div>
      {% else %}
        {% render 'section-heading', title: section.settings.grid_heading %}
        <div class="products-grid">
          {% render 'static-product-card',
            image_src: 'https://images.unsplash.com/photo-1621155346337-1d19476ba7d6?w=600&q=80&auto=format&fit=crop',
            image_alt: 'Storage',
            badge_label: 'New',
            badge_tone: 'new',
            product_type: 'Kitchen & Storage',
            product_name: 'Bamboo Lid Storage Container Set',
            stars: '★★★★☆',
            reviews: '(64)',
            price_now: 'R 349'
          %}
          {% render 'static-product-card',
            image_src: 'https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=600&q=80&auto=format&fit=crop',
            image_alt: 'Headphones',
            badge_label: 'Sale',
            badge_tone: 'sale',
            product_type: 'Tech Accessories',
            product_name: 'Premium Over-Ear Headphones',
            stars: '★★★★★',
            reviews: '(128)',
            price_now: 'R 899',
            price_was: 'R 1 199',
            price_save: '25% off'
          %}
          {% render 'static-product-card',
            image_src: 'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=600&q=80&auto=format&fit=crop',
            image_alt: 'Kitchen',
            product_type: 'Kitchen & Storage',
            product_name: 'Stainless Steel French Press',
            stars: '★★★★★',
            reviews: '(57)',
            price_now: 'R 299'
          %}
          {% render 'static-product-card',
            image_src: 'https://images.unsplash.com/photo-1507473885765-e6ed057f782c?w=600&q=80&auto=format&fit=crop',
            image_alt: 'Lamp',
            badge_label: 'Sale',
            badge_tone: 'sale',
            product_type: 'Home & Living',
            product_name: 'Touch Lamp – Warm LED Dimmable',
            stars: '★★★★☆',
            reviews: '(89)',
            price_now: 'R 229',
            price_was: 'R 299'
          %}
          {% render 'static-product-card',
            image_src: 'https://images.unsplash.com/photo-1602143407151-7111542de6e8?w=600&q=80&auto=format&fit=crop',
            image_alt: 'Bottle',
            badge_label: 'New',
            badge_tone: 'new',
            product_type: 'Kitchen & Storage',
            product_name: 'Insulated Vacuum Flask 500ml',
            stars: '★★★★☆',
            reviews: '(93)',
            price_now: 'R 189'
          %}
          {% render 'static-product-card',
            image_src: 'https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=600&q=80&auto=format&fit=crop',
            image_alt: 'Watch',
            product_type: 'Tech Accessories',
            product_name: 'Smart Watch – Black Edition',
            stars: '★★★★★',
            reviews: '(211)',
            price_now: 'R 1 249',
            price_was: 'R 1 599',
            price_save: '22% off'
          %}
          {% render 'static-product-card',
            image_src: 'https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=600&q=80&auto=format&fit=crop',
            image_alt: 'Storage box',
            product_type: 'Kitchen & Storage',
            product_name: 'Fabric Storage Cube Organiser',
            stars: '★★★★★',
            reviews: '(34)',
            price_now: 'R 149',
            price_was: 'R 199'
          %}
          {% render 'static-product-card',
            image_src: 'https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=600&q=80&auto=format&fit=crop',
            image_alt: 'Plant',
            product_type: 'Home & Living',
            product_name: 'Indoor Plant Pot Set – Terracotta',
            stars: '★★★★☆',
            reviews: '(48)',
            price_now: 'R 179'
          %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection main",
  "settings": [
    {
      "type": "text",
      "id": "collection_label",
      "label": "Collection label",
      "default": "Browse by Category"
    },
    {
      "type": "text",
      "id": "collection_title",
      "label": "Collection title",
      "default": "Everyday"
    },
    {
      "type": "text",
      "id": "collection_accent",
      "label": "Collection title accent",
      "default": "Essentials"
    },
    {
      "type": "textarea",
      "id": "collection_intro",
      "label": "Collection intro",
      "default": "Explore a collection-led layout that follows the approved Mzansi Select grid rhythm, premium-practical typography, and straightforward browse flow while real catalogue wiring remains deferred."
    },
    {
      "type": "text",
      "id": "grid_heading",
      "label": "Grid heading",
      "default": "Featured in this category"
    },
    {
      "type": "select",
      "id": "view_state",
      "label": "View state",
      "default": "filled",
      "options": [
        {
          "value": "filled",
          "label": "Filled"
        },
        {
          "value": "empty",
          "label": "Empty"
        }
      ]
    },
    {
      "type": "text",
      "id": "empty_badge",
      "label": "Empty badge",
      "default": "Collection Preview"
    },
    {
      "type": "text",
      "id": "empty_title",
      "label": "Empty title",
      "default": "This category is being prepared"
    },
    {
      "type": "textarea",
      "id": "empty_description",
      "label": "Empty description",
      "default": "We have approved the collection layout foundation first. Real products and category-specific wiring will follow in a later approved slice."
    },
    {
      "type": "text",
      "id": "empty_action_label",
      "label": "Empty action label",
      "default": "Continue browsing"
    }
  ]
}
{% endschema %}
