{% assign pilot_trust = settings.controlled_pilot_trust_mode %}
{% assign search_query = search.terms | strip %}
{% assign search_performed = search.performed %}
{% assign search_results_count = search.results_count %}

<section class="search-main-shell">
  <div class="section-inner">
    <div class="search-hero">
      <div class="search-kicker">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        {{ section.settings.search_label }}
      </div>
      <h1 class="search-title">
        {% if search_query != blank %}
          {{ section.settings.search_title }}
          <span class="gold">“{{ search_query | escape }}”</span>
        {% else %}
          {{ section.settings.search_title }}
          {% if section.settings.search_accent != blank %}
            <span class="gold">{{ section.settings.search_accent }}</span>
          {% endif %}
        {% endif %}
      </h1>
      <p class="search-intro">
        {% if pilot_trust %}
          Invite-only preview search — not a public launch. Results show only items visible in this password-gated preview. Final pricing, delivery, and purchase remain disabled.
        {% else %}
          {{ section.settings.search_intro }}
        {% endif %}
      </p>

      <form
        class="search-utility"
        action="{{ routes.search_url }}"
        method="get"
        role="search"
        aria-label="Preview product search"
      >
        <div class="search-field-shell">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <label class="visually-hidden" for="SearchPageQuery">Search preview catalogue</label>
          <input
            id="SearchPageQuery"
            type="search"
            name="q"
            value="{{ search_query | escape }}"
            placeholder="{{ settings.search_placeholder | default: 'Search preview products' | escape }}"
            autocomplete="off"
          >
        </div>
        <input type="hidden" name="type" value="product">
        <button class="btn-dark search-button-shell" type="submit">
          {% if pilot_trust %}Search preview{% else %}Search{% endif %}
        </button>
      </form>
    </div>

    <div class="search-summary-card">
      <div class="search-summary-label">{{ section.settings.query_label }}</div>
      <p class="search-summary-copy">
        {% if search_performed and search_query != blank %}
          {% if search_results_count > 0 %}
            {% if search_results_count == 1 %}
              One preview match for “{{ search_query | escape }}”. This is not the full catalogue. Purchase actions stay unavailable; pricing and delivery are not final.
            {% else %}
              {{ search_results_count }} preview matches for “{{ search_query | escape }}”. This is not the full catalogue. Purchase actions stay unavailable; pricing and delivery are not final.
            {% endif %}
          {% else %}
            No preview products matched “{{ search_query | escape }}”. Try another preview search term or browse the approved departments below.
          {% endif %}
        {% elsif search_query != blank %}
          Press Search preview to run this query across visible preview products only.
        {% else %}
          Enter a preview search term above. Results use live Shopify product data where published to this preview — not static demo cards.
        {% endif %}
      </p>
    </div>

    <div class="search-body">
      {% if search_performed and search_query != blank %}
        {% if search_results_count > 0 %}
          {% paginate search.results by 24 %}
            {% render 'section-heading', title: section.settings.results_heading %}
            <div class="products-grid search-results-grid">
              {% for item in search.results %}
                {% if item.object_type == 'product' %}
                  {% render 'live-product-card', product: item %}
                {% endif %}
              {% endfor %}
            </div>
            {% if paginate.pages > 1 %}
              <nav class="search-pagination" aria-label="Search results pages">
                {% if paginate.previous %}
                  <a class="search-pagination-link" href="{{ paginate.previous.url }}">Previous</a>
                {% endif %}
                <span class="search-pagination-status">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
                {% if paginate.next %}
                  <a class="search-pagination-link" href="{{ paginate.next.url }}">Next</a>
                {% endif %}
              </nav>
            {% endif %}
          {% endpaginate %}
        {% else %}
          <div class="search-empty-wrap">
            {% render 'empty-state',
              badge: section.settings.empty_badge,
              title: 'No preview matches',
              description: 'Try another preview search term. This search only covers products visible in the restricted preview — not the full catalogue, final pricing, or orderability.',
              action_label: section.settings.empty_action_label,
              action_url: routes.root_url
            %}
          </div>
        {% endif %}
      {% else %}
        <div class="search-empty-wrap search-empty-wrap--prompt">
          {% render 'empty-state',
            badge: section.settings.empty_badge,
            title: 'Start a preview search',
            description: 'Use the field above to search preview catalogue products. Add to Cart, checkout, and customer account flows remain disabled.',
            action_label: blank,
            action_url: routes.root_url
          %}
        </div>
      {% endif %}
    </div>

    <div class="search-browse-prompt">
      <div class="search-browse-title">{{ section.settings.browse_title }}</div>
      <p class="search-browse-copy">{{ section.settings.browse_copy }}</p>
      <div class="search-browse-links">
        <a class="search-browse-link" href="{% render 'launch-collection-url', handle: 'home-living' %}">Home & Living</a>
        <a class="search-browse-link" href="{% render 'launch-collection-url', handle: 'kitchen-storage' %}">Kitchen & Storage</a>
        <a class="search-browse-link" href="{% render 'launch-collection-url', handle: 'office-desk' %}">Office & Desk</a>
        <a class="search-browse-link" href="{% render 'launch-collection-url', handle: 'tech-accessories' %}">Tech Accessories</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Search main",
  "settings": [
    {
      "type": "text",
      "id": "search_label",
      "label": "Search label",
      "default": "Search Preview"
    },
    {
      "type": "text",
      "id": "search_title",
      "label": "Search title",
      "default": "Search"
    },
    {
      "type": "text",
      "id": "search_accent",
      "label": "Search accent",
      "default": "Results"
    },
    {
      "type": "textarea",
      "id": "search_intro",
      "label": "Search intro",
      "default": "Invite-only controlled pilot search — not a public launch. Live results use Shopify product data visible in preview. Final ranking, pricing, and purchase actions remain disabled."
    },
    {
      "type": "text",
      "id": "query_label",
      "label": "Query label",
      "default": "Preview query"
    },
    {
      "type": "text",
      "id": "results_heading",
      "label": "Results heading",
      "default": "Preview matches"
    },
    {
      "type": "text",
      "id": "empty_badge",
      "label": "Empty badge",
      "default": "Search Preview"
    },
    {
      "type": "text",
      "id": "empty_action_label",
      "label": "Empty action label",
      "default": "Continue browsing"
    },
    {
      "type": "text",
      "id": "browse_title",
      "label": "Browse title",
      "default": "Still exploring?"
    },
    {
      "type": "textarea",
      "id": "browse_copy",
      "label": "Browse copy",
      "default": "Browse launch-department links for orientation only — controlled pilot does not imply the full catalogue is available."
    }
  ]
}
{% endschema %}
