<section class="search-main-shell">
  <div class="section-inner">
    <div class="search-hero">
      <div class="search-kicker">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        {{ section.settings.search_label }}
      </div>
      <h1 class="search-title">
        {{ section.settings.search_title }}
        {% if section.settings.search_accent != blank %}
          <span class="gold">{{ section.settings.search_accent }}</span>
        {% endif %}
      </h1>
      <p class="search-intro">{{ section.settings.search_intro }}</p>

      <div class="search-utility">
        <div class="search-field-shell">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input type="text" value="{{ section.settings.query_value }}" aria-label="Search preview query" readonly>
        </div>
        <button class="btn-dark search-button-shell" type="button" disabled aria-disabled="true">Preview only</button>
      </div>
    </div>

    <div class="search-summary-card">
      <div class="search-summary-label">{{ section.settings.query_label }}</div>
      <p class="search-summary-copy">{{ section.settings.summary_copy }}</p>
    </div>

    {% if section.settings.view_state == 'empty' %}
      {% render 'empty-state',
        badge: section.settings.empty_badge,
        title: section.settings.empty_title,
        description: section.settings.empty_description,
        action_label: section.settings.empty_action_label,
        action_url: routes.root_url
      %}
    {% else %}
      {% render 'section-heading', title: section.settings.results_heading %}
      <div class="products-grid">
        {% assign search_preview_cards = 'headphones-premium.jpg|Headphones|Tech Accessories|Premium Over-Ear Headphones|★★★★★|(128),smart-watch-black-edition.jpg|Watch|Tech Accessories|Smart Watch – Black Edition|★★★★★|(211),bamboo-storage-containers.jpg|Storage|Kitchen & Storage|Bamboo Lid Storage Container Set|★★★★☆|(64),insulated-vacuum-flask.jpg|Bottle|Kitchen & Storage|Insulated Vacuum Flask 500ml|★★★★☆|(93)' | split: ',' %}
        {% for card in search_preview_cards %}
          {% assign card_parts = card | split: '|' %}
          <div class="product-card">
            <div class="prod-img">
              <img
                src="{{ card_parts[0] | asset_url }}"
                alt="{{ card_parts[1] }}"
                loading="lazy"
                width="600"
                height="600"
              >
              <span class="p-badge preview">Preview item</span>
              <button
                class="p-wish"
                type="button"
                disabled
                aria-disabled="true"
                aria-label="Favourites paused. Save feature coming later during private preview."
              >
                <svg width="14" height="14" fill="none" stroke="#666" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                </svg>
              </button>
            </div>
            <div class="prod-info">
              <div class="p-type">{{ card_parts[2] }}</div>
              <div class="p-name">{{ card_parts[3] }}</div>
              <div class="p-stars">{{ card_parts[4] }} <span class="p-rev">{{ card_parts[5] }}</span></div>
              <div class="p-price is-placeholder">
                <span class="p-now is-placeholder">Price to be confirmed</span>
              </div>
              <button
                class="add-btn"
                type="button"
                disabled
                aria-disabled="true"
                aria-label="Preview only. Add to Cart is not available for this item yet."
              >
                Preview only
              </button>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    <div class="search-browse-prompt">
      <div class="search-browse-title">{{ section.settings.browse_title }}</div>
      <p class="search-browse-copy">{{ section.settings.browse_copy }}</p>
      <div class="search-browse-links">
        <a class="search-browse-link" href="{% render 'launch-collection-url', handle: 'home-living' %}">Home & Living</a>
        <a class="search-browse-link" href="{% render 'launch-collection-url', handle: 'kitchen-storage' %}">Kitchen & Storage</a>
        <a class="search-browse-link" href="{% render 'launch-collection-url', handle: 'office-desk' %}">Office & Desk</a>
        <a class="search-browse-link" href="{% render 'launch-collection-url', handle: 'tech-accessories' %}">Tech Accessories</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Search main",
  "settings": [
    {
      "type": "text",
      "id": "search_label",
      "label": "Search label",
      "default": "Search Preview"
    },
    {
      "type": "text",
      "id": "search_title",
      "label": "Search title",
      "default": "Search"
    },
    {
      "type": "text",
      "id": "search_accent",
      "label": "Search accent",
      "default": "Results"
    },
    {
      "type": "textarea",
      "id": "search_intro",
      "label": "Search intro",
      "default": "This preview-safe search foundation keeps the approved Mzansi Select rhythm in place while live search results, final pricing, and purchase actions remain deferred."
    },
    {
      "type": "text",
      "id": "query_label",
      "label": "Query label",
      "default": "Preview query"
    },
    {
      "type": "text",
      "id": "query_value",
      "label": "Query value",
      "default": "wireless headphones"
    },
    {
      "type": "textarea",
      "id": "summary_copy",
      "label": "Summary copy",
      "default": "Showing placeholder preview items only. Purchase actions are unavailable in preview, and live search ranking and fulfilment details remain deferred."
    },
    {
      "type": "text",
      "id": "results_heading",
      "label": "Results heading",
      "default": "Preview matches"
    },
    {
      "type": "select",
      "id": "view_state",
      "label": "View state",
      "default": "filled",
      "options": [
        {
          "value": "filled",
          "label": "Filled"
        },
        {
          "value": "empty",
          "label": "Empty"
        }
      ]
    },
    {
      "type": "text",
      "id": "empty_badge",
      "label": "Empty badge",
      "default": "Search Preview"
    },
    {
      "type": "text",
      "id": "empty_title",
      "label": "Empty title",
      "default": "No products found yet"
    },
    {
      "type": "textarea",
      "id": "empty_description",
      "label": "Empty description",
      "default": "The no-results experience is now in place, but live search terms, product results, and browse recovery behaviour remain intentionally deferred."
    },
    {
      "type": "text",
      "id": "empty_action_label",
      "label": "Empty action label",
      "default": "Continue browsing"
    },
    {
      "type": "text",
      "id": "browse_title",
      "label": "Browse title",
      "default": "Still exploring?"
    },
    {
      "type": "textarea",
      "id": "browse_copy",
      "label": "Browse copy",
      "default": "Browse the same trusted departments already established across the homepage and collection foundations while live search data and ranking remain out of scope for this slice."
    }
  ]
}
{% endschema %}
