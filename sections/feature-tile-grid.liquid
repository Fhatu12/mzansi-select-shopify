<section id="{{ section.settings.anchor_id | escape }}" class="section section-cream section-no-top">
  <div class="section-inner">
    {% render 'section-heading',
      title: section.settings.section_title,
      accent: section.settings.section_accent,
      link_label: section.settings.section_link_label,
      link_url: section.settings.section_link_url
    %}
    <div class="arrivals-grid">
      <div class="arr-card">
        <img src="{{ 'modern-living-room.jpg' | asset_url }}" alt="Living room" loading="lazy" width="900" height="720">
        <div class="arr-overlay">
          <div class="arr-cat">Home &amp; Living</div>
          <div class="arr-name">Modern Living Room Collection</div>
          <a class="arr-link" href="{% render 'launch-collection-url', handle: 'home-living' %}">
            Explore now
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      </div>
      <div class="arr-card">
        <img src="{{ 'smart-watch-black-edition.jpg' | asset_url }}" alt="Tech" loading="lazy" width="900" height="720">
        <div class="arr-overlay">
          <div class="arr-cat">Tech Accessories</div>
          <div class="arr-name">Tech Essentials Preview</div>
          <a class="arr-link" href="{% render 'launch-collection-url', handle: 'tech-accessories' %}">
            Explore now
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Feature tile grid",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "default": "new-in"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section title",
      "default": "Latest"
    },
    {
      "type": "text",
      "id": "section_accent",
      "label": "Section accent",
      "default": "Preview"
    },
    {
      "type": "text",
      "id": "section_link_label",
      "label": "Section link label",
      "default": "View latest preview"
    },
    {
      "type": "url",
      "id": "section_link_url",
      "label": "Section link URL"
    }
  ],
  "presets": [
    {
      "name": "Feature tile grid"
    }
  ]
}
{% endschema %}
