{% liquid
  capture home_living_url
    render 'launch-collection-url', handle: 'home-living'
  endcapture
  assign home_living_url = home_living_url | strip

  capture tech_accessories_url
    render 'launch-collection-url', handle: 'tech-accessories'
  endcapture
  assign tech_accessories_url = tech_accessories_url | strip
%}

<section id="{{ section.settings.anchor_id | escape }}" class="section section-cream section-no-top section--feature-tiles">
  <div class="section-inner">
    {% render 'section-heading',
      title: section.settings.section_title,
      accent: section.settings.section_accent,
      link_label: section.settings.section_link_label,
      link_url: section.settings.section_link_url
    %}
    <div class="arrivals-grid arrivals-grid--homepage">
      <div class="arr-card">
        {% render 'decorative-image', asset: 'modern-living-room.jpg', alt: 'Decorative home collection preview', width: 900, height: 720 %}
        <div class="arr-overlay">
          <div class="arr-cat">Home &amp; Living</div>
          <div class="arr-name">Modern Living Room Collection</div>
          {% if home_living_url != blank and home_living_url != '#' %}
            <a class="arr-link" href="{{ home_living_url }}">
              Explore now
              <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          {% else %}
            <span class="arr-link arr-link--deferred" aria-disabled="true">
              Explore now
              <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
              <span class="visually-hidden">Browse link pending destination approval.</span>
            </span>
          {% endif %}
        </div>
      </div>
      <div class="arr-card">
        {% render 'decorative-image', asset: 'smart-watch-black-edition.jpg', alt: 'Decorative tech collection preview', width: 900, height: 720 %}
        <div class="arr-overlay">
          <div class="arr-cat">Tech Accessories</div>
          <div class="arr-name">New Tech Essentials Drop</div>
          {% if tech_accessories_url != blank and tech_accessories_url != '#' %}
            <a class="arr-link" href="{{ tech_accessories_url }}">
              Explore now
              <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          {% else %}
            <span class="arr-link arr-link--deferred" aria-disabled="true">
              Explore now
              <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
              <span class="visually-hidden">Browse link pending destination approval.</span>
            </span>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Feature tile grid",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "default": "new-in"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section title",
      "default": "Latest"
    },
    {
      "type": "text",
      "id": "section_accent",
      "label": "Section accent",
      "default": "Preview"
    },
    {
      "type": "text",
      "id": "section_link_label",
      "label": "Section link label",
      "default": "View latest preview"
    },
    {
      "type": "url",
      "id": "section_link_url",
      "label": "Section link URL"
    }
  ],
  "presets": [
    {
      "name": "Feature tile grid"
    }
  ]
}
{% endschema %}
