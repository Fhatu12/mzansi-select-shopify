<section id="deals" class="section section-no-top">
  <div class="section-inner">
    <div class="promo-banner promo-banner--homepage">
      <div class="promo-text">
        <div class="promo-eyebrow">Preview highlight</div>
        <div class="promo-h">Tech &amp; Home<br>Preview Picks</div>
        <div class="promo-sub">Preview picks for the products you actually need — selected for South African homes.</div>
        <a class="promo-cta" href="{{ routes.all_products_collection_url }}">
          Browse preview picks
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>
      <div class="promo-visual">
        <img src="{{ 'promo-tech-home-bundles.jpg' | asset_url }}" alt="Preview banner" loading="lazy" width="900" height="640">
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Promo banner split",
  "settings": [],
  "presets": [
    {
      "name": "Promo banner split"
    }
  ]
}
{% endschema %}
