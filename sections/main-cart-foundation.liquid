{% assign pilot_trust = settings.controlled_pilot_trust_mode %}
<section class="cart-main-shell">
  <div class="section-inner">
    <div class="cart-hero">
      <div class="cart-kicker">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        {{ section.settings.cart_label }}
      </div>
      <h1 class="cart-title">
        {{ section.settings.cart_title }}
        {% if section.settings.cart_accent != blank %}
          <span class="gold">{{ section.settings.cart_accent }}</span>
        {% endif %}
      </h1>
      <p class="cart-intro">{{ section.settings.cart_intro }}</p>
    </div>

    {% if cart.item_count == 0 %}
      <div class="cart-empty-wrap">
        {% render 'empty-state',
          badge: section.settings.empty_badge,
          title: section.settings.empty_title,
          description: section.settings.empty_description,
          action_label: section.settings.empty_action_label,
          action_url: routes.root_url
        %}
      </div>
    {% else %}
      <div class="cart-layout">
        <div class="cart-lines-card">
          {% render 'section-heading', title: 'Items in your bag', link_label: 'Continue shopping', link_url: routes.root_url %}

          <div class="cart-lines-list">
            {% for item in cart.items %}
              {% assign item_badge = 'Live' %}
              {% assign item_tone = 'new' %}
              {% if pilot_trust %}
                {% assign item_badge = 'Cart item' %}
                {% assign item_tone = 'new' %}
              {% endif %}
              {% render 'cart-line-item',
                image_src: item.image | image_url: width: 220,
                image_alt: item.product.title,
                badge_label: item_badge,
                badge_tone: item_tone,
                line_index: forloop.index,
                item_key: item.key,
                product_type: item.product.type,
                product_name: item.product.title,
                option_summary: item.variant.title,
                price_now: item.final_price | money_without_trailing_zeros,
                quantity_value: item.quantity,
                line_total: item.final_line_price | money_without_trailing_zeros
              %}
            {% endfor %}
          </div>
        </div>

        <aside class="cart-summary-card">
          <div class="cart-summary-label">{{ section.settings.summary_label }}</div>
          <div class="cart-summary-stack">
            <div class="cart-summary-row">
              <span>Subtotal</span>
              <strong>{{ cart.total_price | money_without_trailing_zeros }}</strong>
            </div>
            <div class="cart-summary-row">
              <span>Delivery</span>
              <span>Calculated at checkout</span>
            </div>
          </div>

          <div class="cart-summary-total">
            <span>Estimated total</span>
            <strong>{{ cart.total_price | money_without_trailing_zeros }}</strong>
          </div>

          <div class="cart-summary-actions">
            <form action="{{ routes.cart_url }}" method="post">
              <button class="btn-dark cart-checkout-shell" type="submit" name="checkout">Proceed to checkout</button>
            </form>
            <a class="btn-ghost cart-secondary-shell" href="{{ routes.all_products_collection_url }}">Continue shopping</a>
          </div>
        </aside>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Cart main",
  "settings": [
    {"type":"text","id":"cart_label","label":"Cart label","default":"Cart"},
    {"type":"text","id":"cart_title","label":"Cart title","default":"Your"},
    {"type":"text","id":"cart_accent","label":"Cart accent","default":"Basket"},
    {"type":"textarea","id":"cart_intro","label":"Cart intro","default":"Review your items and continue to checkout."},
    {"type":"text","id":"summary_label","label":"Summary label","default":"Order summary"},
    {"type":"text","id":"empty_badge","label":"Empty badge","default":"Cart"},
    {"type":"text","id":"empty_title","label":"Empty title","default":"Your basket is still empty"},
    {"type":"textarea","id":"empty_description","label":"Empty description","default":"Add a product to your basket to continue to checkout."},
    {"type":"text","id":"empty_action_label","label":"Empty action label","default":"Continue browsing"}
  ]
}
{% endschema %}
