{% assign current_variant = product.selected_or_first_available_variant %}
{% assign current_product_type = product.type | default: section.settings.product_type %}
{% assign current_product_title = product.title | default: section.settings.product_title %}
{% assign current_product_intro = product.description | strip_html | strip | truncatewords: 28 %}
{% if current_product_intro == blank %}
  {% assign current_product_intro = section.settings.product_intro %}
{% endif %}
{% assign current_product_description = product.description | strip %}
{% include 'product-commerce-gate', gate_product: product %}
{% assign current_product_preview_only = gate_preview_only %}
{% assign current_product_price_to_confirm = gate_price_to_confirm %}
{% assign current_product_non_purchasable = gate_non_purchasable %}
{% assign current_product_commerce_blocked = gate_commerce_blocked %}
{% assign current_image_permission_confirmed = false %}
{% for tag in product.tags %}
  {% assign current_nt = tag | downcase | strip | replace: ' ', '-' %}
  {% if current_nt == 'image-permission-confirmed' %}
    {% assign current_image_permission_confirmed = true %}
  {% endif %}
{% endfor %}
{% assign current_product_use_placeholder_price = false %}
{% if current_product_commerce_blocked %}
  {% assign current_product_use_placeholder_price = true %}
{% endif %}
{% assign current_vendor_norm = product.vendor | downcase | strip %}
{% if current_product_use_placeholder_price == false and current_variant.price <= 0 and current_vendor_norm == 'mzansi select preview' %}
  {% assign current_product_use_placeholder_price = true %}
{% endif %}
{% assign current_product_price = current_variant.price | money_without_trailing_zeros %}
{% assign current_product_price_was = blank %}
{% assign current_product_price_save = blank %}
{% if current_product_use_placeholder_price %}
  {% assign current_product_price = 'Price to be confirmed' %}
{% elsif current_variant.compare_at_price > current_variant.price %}
  {% assign current_product_price_was = current_variant.compare_at_price | money_without_trailing_zeros %}
  {% assign current_product_price_delta = current_variant.compare_at_price | minus: current_variant.price %}
  {% assign current_product_price_percent = current_product_price_delta | times: 100 | divided_by: current_variant.compare_at_price %}
  {% assign current_product_price_save = current_product_price_percent | append: '% off' %}
{% endif %}
{% assign current_show_catalog_media = true %}
{% if current_product_preview_only and current_image_permission_confirmed == false %}
  {% assign current_show_catalog_media = false %}
{% endif %}
{% assign cj_controlled_preview_handles = 'beverage-bottle-oil-bottle-handle-holder,usb-bag-sealer,foldable-magnetic-phone-holder-desktop-tablet-stand' | split: ',' %}
{% if cj_controlled_preview_handles contains product.handle %}
  {% assign current_show_catalog_media = false %}
{% endif %}
{% assign current_media = current_variant.featured_media | default: product.featured_media | default: product.media.first %}
{% unless current_show_catalog_media %}
  {% assign current_media = blank %}
{% endunless %}
{% assign related_collection = product.collections.first %}
{% assign related_products_found = 0 %}
{% assign pilot_trust = settings.controlled_pilot_trust_mode %}
{% if pilot_trust %}
  {% assign current_product_price_was = blank %}
  {% assign current_product_price_save = blank %}
{% endif %}
{% assign product_price_supporting_note = blank %}
{% if pilot_trust and current_product_use_placeholder_price %}
  {% assign product_price_supporting_note = 'Pilot price — not final' %}
{% endif %}

<section class="product-main-shell">
  <div class="section-inner">
    <div class="product-main">
      <div
        class="product-gallery"
        data-product-gallery
        {% if product.media.size > 1 and current_show_catalog_media %}data-gallery-multiple="true"{% endif %}
        tabindex="0"
        aria-label="Product images"
      >
        <div class="product-gallery-main" data-gallery-main>
          {% if current_media %}
            {% assign gallery_main_src = current_media.preview_image | image_url: width: 1200 %}
            <img
              class="product-gallery-main-image"
              data-gallery-main-image
              data-media-id="{{ current_media.id }}"
              src="{{ current_media.preview_image | image_url: width: 720 }}"
              srcset="{{ gallery_main_src }} 1200w"
              alt="{{ current_media.alt | default: current_product_title | escape }}"
              loading="eager"
              width="{{ current_media.preview_image.width }}"
              height="{{ current_media.preview_image.height }}"
            >
            <div class="product-gallery-zoom-pane" data-gallery-zoom-pane" aria-hidden="true"></div>
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'product-gallery-placeholder' }}
          {% endif %}
          {% if product.media.size > 1 and current_show_catalog_media %}
            <button type="button" class="product-gallery-nav product-gallery-nav--prev" data-gallery-prev aria-label="Previous image">
              <span aria-hidden="true">‹</span>
            </button>
            <button type="button" class="product-gallery-nav product-gallery-nav--next" data-gallery-next aria-label="Next image">
              <span aria-hidden="true">›</span>
            </button>
          {% endif %}
        </div>
        {% if product.media.size > 0 and current_show_catalog_media %}
          <div class="product-gallery-strip" role="tablist" aria-label="Product image thumbnails">
            {% for media in product.media %}
              {% assign thumb_src = media.preview_image | image_url: width: 180 %}
              {% assign thumb_full = media.preview_image | image_url: width: 1200 %}
              <button
                type="button"
                class="product-gallery-thumb{% if current_media and media.id == current_media.id %} is-active{% endif %}"
                data-gallery-thumb
                data-media-id="{{ media.id }}"
                data-media-src="{{ thumb_full }}"
                data-media-alt="{{ media.alt | default: current_product_title | escape }}"
                data-media-width="{{ media.preview_image.width }}"
                data-media-height="{{ media.preview_image.height }}"
                role="tab"
                aria-selected="{% if current_media and media.id == current_media.id %}true{% else %}false{% endif %}"
                aria-label="View image {{ forloop.index }} of {{ product.media.size }}"
              >
                <img
                  src="{{ thumb_src }}"
                  alt=""
                  loading="lazy"
                  width="{{ media.preview_image.width }}"
                  height="{{ media.preview_image.height }}"
                >
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="product-summary">
        <div class="product-main-kicker">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          {{ section.settings.product_label }}
        </div>

        <div class="product-main-badge-row">
          {% if current_product_commerce_blocked %}
            {% if pilot_trust %}
              {% render 'product-badge', label: 'Pilot item', tone: 'preview' %}
            {% else %}
              {% render 'product-badge', label: 'Preview item', tone: 'preview' %}
            {% endif %}
          {% elsif current_variant.compare_at_price > current_variant.price and current_product_use_placeholder_price == false %}
            {% unless pilot_trust %}
              {% render 'product-badge', label: 'Sale', tone: 'sale' %}
            {% endunless %}
          {% endif %}
        </div>

        <div class="p-type product-main-type">{{ current_product_type }}</div>
        <h1 class="product-main-title">{{ current_product_title }}</h1>
        {% render 'price-stack',
          price_now: current_product_price,
          price_was: current_product_price_was,
          price_save: current_product_price_save,
          price_is_placeholder: current_product_use_placeholder_price,
          supporting_note: product_price_supporting_note
        %}
        {% if current_product_preview_only and pilot_trust %}
          <p class="product-preview-note">Delivery timing will be confirmed before launch. This preview item is not yet available for purchase.</p>
          <p class="product-preview-note">Returns and warranty handling will be confirmed before launch. Statutory consumer rights are not limited by this preview page.</p>
        {% elsif current_product_commerce_blocked %}
          <p class="product-preview-note">This product is being prepared for launch. Delivery details to be confirmed before launch.</p>
        {% elsif pilot_trust %}
          <p class="product-preview-note">Controlled pilot view — not a public launch. Delivery and returns will be confirmed before any order fulfilment.</p>
        {% endif %}

        <p class="product-main-intro">{{ current_product_intro }}</p>

        {% unless product.has_only_default_variant %}
          <div class="product-options-preview" data-product-options>
            <script type="application/json" data-product-options-json>
              {
                "options": [
                  {% for option in product.options_with_values %}
                    {
                      "name": {{ option.name | json }},
                      "position": {{ option.position }},
                      "selected": {{ option.selected_value | json }},
                      "values": {{ option.values | json }}
                    }{% unless forloop.last %},{% endunless %}
                  {% endfor %}
                ],
                "variants": [
                  {% for variant in product.variants %}
                    {
                      "id": {{ variant.id }},
                      "available": {{ variant.available | json }},
                      "options": [
                        {% for opt in variant.options %}
                          {{ opt | json }}{% unless forloop.last %},{% endunless %}
                        {% endfor %}
                      ],
                      "featuredSrc": {% if variant.featured_media %}{{ variant.featured_media | image_url: width: 1200 | json }}{% else %}null{% endif %},
                      "featuredAlt": {{ variant.featured_media.alt | default: product.title | json }}
                    }{% unless forloop.last %},{% endunless %}
                  {% endfor %}
                ]
              }
            </script>
            {% for option in product.options_with_values %}
              {% assign option_name_norm = option.name | downcase | strip %}
              {% assign is_colour_option = false %}
              {% if option_name_norm == 'color' or option_name_norm == 'colour' %}
                {% assign is_colour_option = true %}
              {% endif %}
              <div class="product-option-shell" data-option-index="{{ option.position | minus: 1 }}">
                <div class="product-option-label">{{ option.name }}</div>
                <div class="product-option-row{% if is_colour_option %} product-option-row--colour{% endif %}">
                  {% for value in option.values %}
                    <button
                      type="button"
                      class="{% if is_colour_option %}product-option-swatch{% else %}product-option-chip{% endif %}{% if value == option.selected_value %} is-active{% endif %}"
                      data-option-value="{{ value | escape }}"
                      aria-pressed="{% if value == option.selected_value %}true{% else %}false{% endif %}"
                    >
                      {% if is_colour_option %}
                        <span class="product-option-swatch-label" title="{{ value | escape }}">{{ value }}</span>
                      {% else %}
                        {{ value }}
                      {% endif %}
                    </button>
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
          </div>
        {% endunless %}

        <p class="product-purchase-note">
          {% if current_product_commerce_blocked %}
            Price to be confirmed. This product is being prepared for launch. Cart, checkout, and payments are not available.
          {% elsif pilot_trust %}
            Invite-only controlled pilot visibility. Not a public launch. Cart and checkout remain disabled until a separate Product Owner go/no-go.
          {% else %}
            Preview visibility only. Cart and checkout actions remain disabled in this slice.
          {% endif %}
        </p>
        <div class="product-purchase-shell">
          <div class="product-qty-wrap">
            <div class="product-option-label">Quantity</div>
            <div class="product-qty-shell" aria-label="Quantity selector">
              <button class="product-qty-btn" type="button" aria-label="Decrease quantity" disabled>−</button>
              <div class="product-qty-value">1</div>
              <button class="product-qty-btn" type="button" aria-label="Increase quantity" disabled>+</button>
            </div>
          </div>
          <div class="product-action-row">
            <button class="add-btn product-main-add" type="button" disabled aria-disabled="true"{% if current_product_commerce_blocked %} aria-label="Price to be confirmed. This product is being prepared for launch."{% endif %}>{% if current_product_commerce_blocked %}Price to be confirmed{% elsif pilot_trust %}Not available to buy yet{% else %}Preview only{% endif %}</button>
            {% render 'wishlist-button', product: product %}
          </div>
        </div>

        <div class="product-reassurance-list">
          <div class="product-reassurance-item">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <rect x="1" y="3" width="15" height="13" rx="1"></rect>
              <path d="M16 8h5l2 5v4h-7V8z"></path>
              <circle cx="5.5" cy="18.5" r="2.5"></circle>
              <circle cx="18.5" cy="18.5" r="2.5"></circle>
            </svg>
            {% if pilot_trust %}
              Invite-only pilot: live titles and layout may render for review. Pricing is not final; this is not a full catalogue launch.
            {% elsif current_product_preview_only or current_product_use_placeholder_price %}
              Live Shopify product titles and catalog layout render in preview; price is not final until separately approved.
            {% else %}
              Live Shopify product title, media, and pricing now render in preview
            {% endif %}
          </div>
          <div class="product-reassurance-item">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
            {% if pilot_trust %}
              Final pricing, guaranteed delivery, and public launch approval are not granted on this page.
            {% else %}
              Final pricing, delivery, and launch approval remain pending
            {% endif %}
          </div>
          <div class="product-reassurance-item">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <polyline points="1 4 1 10 7 10"></polyline>
              <path d="M3.51 15a9 9 0 1 0 .49-4.95"></path>
            </svg>
            {% if pilot_trust %}
              Add to Cart, wishlist, checkout, and payments stay disabled here.
            {% else %}
              Add to Cart, wishlist, and checkout behaviour remain deferred
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    <div class="product-detail-grid">
      <div class="product-detail-card">
        <div class="product-detail-title">{{ section.settings.description_title }}</div>
        {% if current_product_description != blank %}
          <div class="product-detail-copy">{{ product.description }}</div>
        {% else %}
          <p class="product-detail-copy">{{ section.settings.description_copy }}</p>
        {% endif %}
      </div>
      <div class="product-detail-card">
        <div class="product-detail-title">{{ section.settings.specs_title }}</div>
        <ul class="product-spec-list">
          {% if product != blank %}
            {% if product.vendor != blank %}
              <li>Vendor: {{ product.vendor }}</li>
            {% endif %}
            {% if product.type != blank %}
              <li>Type: {{ product.type }}</li>
            {% endif %}
            <li>Availability: {% if current_product_commerce_blocked %}{% if pilot_trust %}Pilot preview item{% else %}Preview catalogue item — not available to buy{% endif %}{% elsif product.available %}Shown for preview — not a stock guarantee{% else %}Currently unavailable{% endif %}</li>
            <li>Variant count: {{ product.variants.size }}</li>
            {% unless product.has_only_default_variant %}
              <li>Options: {{ product.options | join: ', ' }}</li>
            {% endunless %}
            {% if current_variant.sku != blank %}
              <li>SKU: {{ current_variant.sku }}</li>
            {% endif %}
          {% else %}
            {% assign product_specs = section.settings.specs_copy | newline_to_br | split: '<br />' %}
            {% for spec in product_specs %}
              {% if spec != blank %}
                <li>{{ spec | strip }}</li>
              {% endif %}
            {% endfor %}
          {% endif %}
        </ul>
      </div>
    </div>

    <div class="product-support-band">
      <div class="product-support-item">
        <div class="product-support-title">{% if pilot_trust %}Controlled pilot support{% else %}Need help before ordering?{% endif %}</div>
        <div class="product-support-copy">
          {% if pilot_trust %}
            This invite-only pilot is not a public launch. Use these pages to review titles, media, and descriptions; operational support is limited until checkout is separately approved.
          {% else %}
            Use this preview to review live product titles, media, and description coverage before any launch-readiness decision is requested.
          {% endif %}
        </div>
      </div>
      <div class="product-support-item">
        <div class="product-support-title">{% if pilot_trust %}Pricing and claims{% else %}Straightforward value{% endif %}</div>
        <div class="product-support-copy">
          {% if pilot_trust %}
            No final pricing, no supplier-verified labelling, and no unsupported product claims are implied here. Commercial sign-off stays separate.
          {% else %}
            Final pricing, fulfilment, returns, and sales claims still need separate commercial and operational approval.
          {% endif %}
        </div>
      </div>
      <div class="product-support-item">
        <div class="product-support-title">{% if pilot_trust %}Checkout and accounts{% else %}Ready for later wiring{% endif %}</div>
        <div class="product-support-copy">
          {% if pilot_trust %}
            Cart, checkout, payments, customer accounts, wishlist, and newsletter capture remain disabled or deferred unless a later go/no-go enables them.
          {% else %}
            Live cart, checkout, and other transactional behaviours remain intentionally deferred for a later approved slice.
          {% endif %}
        </div>
      </div>
    </div>

    {% if related_collection != blank and related_collection.all_products_count > 1 %}
      <div class="product-related-shell">
        {% render 'section-heading',
          title: 'More from',
          accent: related_collection.title,
          link_label: 'Browse all products',
          link_url: routes.all_products_collection_url
        %}
        <div class="products-grid">
          {% for related_product in related_collection.products %}
            {% if related_product.id != product.id %}
              {% render 'live-product-card', product: related_product, collection_context: related_collection %}
              {% assign related_products_found = related_products_found | plus: 1 %}
            {% endif %}
            {% if related_products_found == 4 %}
              {% break %}
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Product main",
  "settings": [
    {
      "type": "text",
      "id": "product_label",
      "label": "Product label",
      "default": "Controlled pilot preview"
    },
    {
      "type": "text",
      "id": "product_type",
      "label": "Product type",
      "default": "Tech Accessories"
    },
    {
      "type": "text",
      "id": "product_title",
      "label": "Product title",
      "default": "Premium Over-Ear Headphones"
    },
    {
      "type": "text",
      "id": "product_reviews",
      "label": "Review summary",
      "default": "(128 verified reviews)"
    },
    {
      "type": "text",
      "id": "price_now",
      "label": "Current price",
      "default": "R 899"
    },
    {
      "type": "text",
      "id": "price_was",
      "label": "Previous price",
      "default": "R 1 199"
    },
    {
      "type": "text",
      "id": "price_save",
      "label": "Savings label",
      "default": "25% off"
    },
    {
      "type": "textarea",
      "id": "product_intro",
      "label": "Product intro",
      "default": "A static-safe product detail foundation that preserves the approved Mzansi Select balance of premium presentation, clear pricing, and practical support cues while live Shopify product wiring remains deferred."
    },
    {
      "type": "text",
      "id": "description_title",
      "label": "Description title",
      "default": "Product Overview"
    },
    {
      "type": "textarea",
      "id": "description_copy",
      "label": "Description copy",
      "default": "Designed for everyday listening, work calls, and travel, this product detail page shell mirrors the approved storefront language with a clean gallery-first layout, compact pricing hierarchy, and straightforward support reassurance. Final catalog data and transactional behaviour remain deferred to a later approved slice."
    },
    {
      "type": "text",
      "id": "specs_title",
      "label": "Specifications title",
      "default": "Specifications"
    },
    {
      "type": "textarea",
      "id": "specs_copy",
      "label": "Specifications copy",
      "default": "Wireless Bluetooth connectivity\nUp to 28 hours playback\nFold-flat travel design\nSoft over-ear cushions\nUSB-C charging cable included"
    },
    {
      "type": "text",
      "id": "related_heading",
      "label": "Related heading",
      "default": "You may also"
    },
    {
      "type": "text",
      "id": "related_accent",
      "label": "Related accent",
      "default": "like"
    }
  ]
}
{% endschema %}
