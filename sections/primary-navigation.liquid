{% liquid
  assign preview_selected_picks_url = routes.root_url | append: '#best-sellers'
  assign preview_latest_url = routes.root_url | append: '#new-in'
  assign preview_picks_url = routes.root_url | append: '#deals'
  assign about_page_url = '/pages/about'
  assign contact_page_url = '/pages/contact#contact'
%}

<nav class="site-nav-desktop" data-shell="desktop-nav">
  <div class="nav-inner">
    <div class="dept-wrap">
      <button class="dept-btn" type="button" aria-expanded="false" aria-controls="desktopDepartmentMenu" aria-haspopup="true">
        <span class="hamburger" aria-hidden="true"><span></span><span></span><span></span></span>
        Shop by Department
        <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
      <div class="dept-menu" id="desktopDepartmentMenu">
        <a class="dept-item" href="{% render 'launch-collection-url', handle: 'home-living' %}"><span class="dept-item-icon">🛋️</span> Home &amp; Living</a>
        <a class="dept-item" href="{% render 'launch-collection-url', handle: 'kitchen-storage' %}"><span class="dept-item-icon">🍳</span> Kitchen &amp; Storage</a>
        <a class="dept-item" href="{% render 'launch-collection-url', handle: 'office-desk' %}"><span class="dept-item-icon">💼</span> Office &amp; Desk</a>
        <a class="dept-item" href="{% render 'launch-collection-url', handle: 'tech-accessories' %}"><span class="dept-item-icon">🎧</span> Tech Accessories</a>
        <a class="dept-item" href="{% render 'launch-collection-url', handle: 'retro-vault-consoles-classics' %}"><span class="dept-item-icon">🕹️</span> The Retro Vault</a>
        <a class="dept-item" href="{% render 'launch-collection-url', handle: 'games-toys' %}"><span class="dept-item-icon">🎮</span> Games &amp; Toys</a>
        <span class="dept-item dept-item--deferred" aria-disabled="true"><span class="dept-item-icon">🌿</span> Garden &amp; Outdoor</span>
        <span class="dept-item dept-item--deferred" aria-disabled="true"><span class="dept-item-icon">🛁</span> Bath &amp; Bedroom</span>
        <span class="dept-item dept-item--deferred" aria-disabled="true"><span class="dept-item-icon">🧹</span> Cleaning &amp; Laundry</span>
      </div>
    </div>

    <ul class="nav-links">
      <li><a href="{{ routes.root_url }}" class="active">Home</a></li>
      <li><a href="{{ routes.all_products_collection_url }}">Shop All</a></li>
      <li><a href="{{ preview_latest_url }}">New In</a></li>
      <li><a href="{{ preview_selected_picks_url }}">Best Sellers</a></li>
      <li><a href="{{ preview_picks_url }}">Deals</a></li>
      <li><span class="nav-link-deferred" aria-disabled="true">Brands</span></li>
    </ul>

    <div class="nav-right">
      <div class="nav-badge">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <rect x="1" y="3" width="15" height="13" rx="1"></rect>
          <path d="M16 8h5l2 5v4h-7V8z"></path>
          <circle cx="5.5" cy="18.5" r="2.5"></circle>
          <circle cx="18.5" cy="18.5" r="2.5"></circle>
        </svg>
        Delivery review
      </div>
      <div class="nav-badge">
        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
          <circle cx="12" cy="10" r="3"></circle>
        </svg>
        South Africa only
      </div>
    </div>
  </div>
</nav>

<button class="drawer-overlay" id="drawerOverlay" data-shell="mobile-overlay" type="button" aria-label="Close menu"></button>

<aside class="nav-drawer" id="navDrawer" data-shell="mobile-drawer" aria-hidden="true">
  <div class="drawer-header">
    <div class="drawer-logo">Mzansi <em>Select</em></div>
    <button class="drawer-close" type="button" id="drawerClose" aria-label="Close menu">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <div class="drawer-section-label">Departments</div>
  <a class="drawer-link mob-drawer-link" href="{% render 'launch-collection-url', handle: 'home-living' %}">
    <span class="drawer-link-icon">🛋️</span>
    Home &amp; Living
    <span class="drawer-link-arrow">&rsaquo;</span>
  </a>
  <a class="drawer-link mob-drawer-link" href="{% render 'launch-collection-url', handle: 'kitchen-storage' %}">
    <span class="drawer-link-icon">🍳</span>
    Kitchen &amp; Storage
    <span class="drawer-link-arrow">&rsaquo;</span>
  </a>
  <a class="drawer-link mob-drawer-link" href="{% render 'launch-collection-url', handle: 'office-desk' %}">
    <span class="drawer-link-icon">💼</span>
    Office &amp; Desk
    <span class="drawer-link-arrow">&rsaquo;</span>
  </a>
  <a class="drawer-link mob-drawer-link" href="{% render 'launch-collection-url', handle: 'tech-accessories' %}">
    <span class="drawer-link-icon">🎧</span>
    Tech Accessories
    <span class="drawer-link-arrow">&rsaquo;</span>
  </a>
  <a class="drawer-link mob-drawer-link" href="{% render 'launch-collection-url', handle: 'retro-vault-consoles-classics' %}">
    <span class="drawer-link-icon">🕹️</span>
    The Retro Vault
    <span class="drawer-link-arrow">&rsaquo;</span>
  </a>
  <a class="drawer-link mob-drawer-link" href="{% render 'launch-collection-url', handle: 'games-toys' %}">
    <span class="drawer-link-icon">🎮</span>
    Games &amp; Toys
    <span class="drawer-link-arrow">&rsaquo;</span>
  </a>

  <div class="drawer-divider"></div>

  <div class="drawer-section-label">Browse</div>
  <a class="drawer-link mob-drawer-link" href="{{ routes.root_url }}">
    <span class="drawer-link-icon">⌂</span>
    Home
  </a>
  <a class="drawer-link mob-drawer-link" href="{{ routes.all_products_collection_url }}">
    <span class="drawer-link-icon">◫</span>
    Shop All
  </a>
  <a class="drawer-link mob-drawer-link" href="{{ preview_latest_url }}">
    <span class="drawer-link-icon">✦</span>
    New In
  </a>
  <a class="drawer-link mob-drawer-link" href="{{ preview_selected_picks_url }}">
    <span class="drawer-link-icon">★</span>
    Best Sellers
  </a>
  <a class="drawer-link mob-drawer-link" href="{{ preview_picks_url }}">
    <span class="drawer-link-icon">%</span>
    Deals
  </a>
  <span class="drawer-link drawer-link--deferred" aria-disabled="true">
    <span class="drawer-link-icon">◌</span>
    Brands
  </span>

  <div class="drawer-divider"></div>

  <div class="drawer-section-label">Help</div>
  <a class="drawer-link mob-drawer-link" href="{{ about_page_url }}#shipping">
    <span class="drawer-link-icon">🚚</span>
    Shipping
  </a>
  <a class="drawer-link mob-drawer-link" href="{{ about_page_url }}#returns">
    <span class="drawer-link-icon">↺</span>
    Returns
  </a>
  <a class="drawer-link mob-drawer-link" href="{{ about_page_url }}#faq">
    <span class="drawer-link-icon">?</span>
    FAQ
  </a>
  <a class="drawer-link mob-drawer-link" href="{{ contact_page_url }}">
    <span class="drawer-link-icon">✆</span>
    Contact Us
  </a>

  <div class="drawer-account">
    <p>Customer accounts are paused during private preview.</p>
    <div class="drawer-btn-row">
      <button class="drawer-btn drawer-btn-outline" type="button" disabled aria-disabled="true">Customer accounts paused</button>
      <button class="drawer-btn drawer-btn-filled" type="button" disabled aria-disabled="true">Cart paused</button>
    </div>
  </div>
</aside>

<nav class="bottom-bar" data-shell="mobile-nav" aria-label="Mobile quick navigation">
  <a class="bb-item" href="{{ routes.root_url }}">
    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
      <polyline points="9 22 9 12 15 12 15 22"></polyline>
    </svg>
    Home
  </a>
  <button class="bb-item" type="button" data-mobile-search-trigger>
    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
    Search
  </button>
  <span class="bb-center bb-item--deferred" aria-disabled="true" aria-label="Cart paused. Cart and checkout remain disabled during private preview.">
    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
      <line x1="3" y1="6" x2="21" y2="6"></line>
      <path d="M16 10a4 4 0 0 1-8 0"></path>
    </svg>
    <span class="bb-cart-badge">{{ cart.item_count }}</span>
  </span>
  <button class="bb-item" type="button" data-wishlist-open data-wishlist-header-state aria-expanded="false" aria-controls="wishlistDrawer" aria-label="Open saved items drawer">
    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
    </svg>
    Saved <span class="wishlist-count-badge wishlist-count-badge--bottom" data-wishlist-count>0</span>
  </button>
  <span class="bb-item bb-item--deferred" aria-disabled="true" aria-label="Account access not active in preview. Customer accounts paused.">
    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
      <circle cx="12" cy="7" r="4"></circle>
    </svg>
    Account
  </span>
</nav>

<div class="wishlist-drawer" id="wishlistDrawer" data-wishlist-drawer aria-hidden="true">
  <button class="wishlist-drawer-backdrop" type="button" data-wishlist-backdrop data-wishlist-close aria-label="Close saved items"></button>
  <aside class="wishlist-drawer-panel" data-wishlist-panel role="dialog" aria-modal="true" aria-label="Saved items">
    <div class="wishlist-drawer-header">
      <h2>Saved items</h2>
      <button type="button" class="wishlist-drawer-close" data-wishlist-close aria-label="Close saved items">Close</button>
    </div>
    <p class="wishlist-drawer-empty" data-wishlist-empty>No saved items yet.</p>
    <ul class="wishlist-drawer-list" data-wishlist-drawer-list></ul>
  </aside>
</div>

{% schema %}
{
  "name": "Primary navigation",
  "settings": []
}
{% endschema %}
