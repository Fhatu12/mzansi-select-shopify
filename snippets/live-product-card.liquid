{% assign card_variant = product.selected_or_first_available_variant %}
{% assign card_product_url = product.url %}
{% if collection_context != blank %}
  {% assign card_product_url = product.url | within: collection_context %}
{% endif %}

{% comment %} Slice 21FC-A: inline tag gate — include is not allowed when this snippet is rendered via {% render %}. {% endcomment %}
{% assign card_non_purchasable = false %}
{% assign card_price_to_confirm = false %}
{% assign card_preview_only = false %}
{% if product != blank %}
  {% for tag in product.tags %}
    {% assign card_gate_nt = tag | downcase | strip | replace: ' ', '-' %}
    {% if card_gate_nt == 'non-purchasable' %}
      {% assign card_non_purchasable = true %}
    {% endif %}
    {% if card_gate_nt == 'price-to-confirm' %}
      {% assign card_price_to_confirm = true %}
    {% endif %}
    {% if card_gate_nt == 'preview-only' %}
      {% assign card_preview_only = true %}
    {% endif %}
  {% endfor %}
{% endif %}
{% assign card_commerce_blocked = false %}
{% if card_non_purchasable or card_price_to_confirm or card_preview_only %}
  {% assign card_commerce_blocked = true %}
{% endif %}
{% assign card_image_permission_confirmed = false %}
{% for tag in product.tags %}
  {% assign card_nt = tag | downcase | strip | replace: ' ', '-' %}
  {% if card_nt == 'image-permission-confirmed' %}
    {% assign card_image_permission_confirmed = true %}
  {% endif %}
{% endfor %}
{% assign card_use_placeholder_price = false %}
{% if card_commerce_blocked %}
  {% assign card_use_placeholder_price = true %}
{% endif %}
{% assign card_vendor_norm = product.vendor | downcase | strip %}
{% if card_use_placeholder_price == false and card_variant.price <= 0 and card_vendor_norm == 'mzansi select preview' %}
  {% assign card_use_placeholder_price = true %}
{% endif %}

{% assign card_price_now = card_variant.price | money_without_trailing_zeros %}
{% assign card_price_was = blank %}
{% assign card_price_save = blank %}
{% if card_use_placeholder_price %}
  {% assign card_price_now = 'Price to be confirmed' %}
{% elsif card_variant.compare_at_price > card_variant.price %}
  {% assign card_price_was = card_variant.compare_at_price | money_without_trailing_zeros %}
  {% assign card_price_delta = card_variant.compare_at_price | minus: card_variant.price %}
  {% assign card_price_percent = card_price_delta | times: 100 | divided_by: card_variant.compare_at_price %}
  {% assign card_price_save = card_price_percent | append: '% off' %}
{% endif %}
{% assign pilot_trust = settings.controlled_pilot_trust_mode %}
{% if pilot_trust %}
  {% assign card_price_was = blank %}
  {% assign card_price_save = blank %}
{% endif %}

{% assign card_show_catalog_media = true %}
{% if card_preview_only and card_image_permission_confirmed == false %}
  {% assign card_show_catalog_media = false %}
{% endif %}
{% assign cj_controlled_preview_handles = 'beverage-bottle-oil-bottle-handle-holder,usb-bag-sealer,foldable-magnetic-phone-holder-desktop-tablet-stand' | split: ',' %}
{% if cj_controlled_preview_handles contains product.handle %}
  {% assign card_show_catalog_media = false %}
{% endif %}
{% assign card_price_note = blank %}
{% if pilot_trust and card_use_placeholder_price %}
  {% assign card_price_note = 'Pilot price — not final' %}
{% endif %}

<div class="product-card product-card--live">
  <div class="prod-img">
    <a href="{{ card_product_url }}" aria-label="View {{ product.title }}">
      {% if product.featured_media and card_show_catalog_media %}
        <img
          src="{{ product.featured_media | image_url: width: 600 }}"
          alt="{{ product.featured_media.alt | default: product.title | escape }}"
          loading="lazy"
          width="600"
          height="600"
        >
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'product-placeholder-svg' }}
      {% endif %}
    </a>
    {% if card_commerce_blocked %}
      {% if pilot_trust %}
        {% render 'product-badge', label: 'Pilot item', tone: 'preview' %}
      {% else %}
        {% render 'product-badge', label: 'Preview item', tone: 'preview' %}
      {% endif %}
    {% elsif card_variant.compare_at_price > card_variant.price and card_use_placeholder_price == false %}
      {% unless pilot_trust %}
        {% render 'product-badge', label: 'Sale', tone: 'sale' %}
      {% endunless %}
    {% endif %}
    <button
      class="p-wish"
      type="button"
      disabled
      aria-disabled="true"
      aria-label="Favourites paused. Save feature coming later for {{ product.title | escape }} during private preview."
    >
      <svg width="14" height="14" fill="none" stroke="#666" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
    </button>
  </div>
  <div class="prod-info">
    <div class="p-type">{{ product.type | default: product.vendor | default: 'Preview product' }}</div>
    <div class="p-name"><a href="{{ card_product_url }}">{{ product.title }}</a></div>
    {% render 'price-stack',
      price_now: card_price_now,
      price_was: card_price_was,
      price_save: card_price_save,
      price_is_placeholder: card_use_placeholder_price,
      supporting_note: card_price_note
    %}
    <a class="add-btn add-btn--browse" href="{{ card_product_url }}">{{ cta_label | default: 'View product' }}</a>
    {% if card_commerce_blocked %}
      <p class="p-commerce-note">Price to be confirmed. This product is being prepared for launch.</p>
    {% endif %}
  </div>
</div>
