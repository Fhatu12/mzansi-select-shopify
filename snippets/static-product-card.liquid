{% assign pilot_trust = settings.controlled_pilot_trust_mode %}
{% assign sc_badge_label = badge_label %}
{% assign sc_badge_tone = badge_tone %}
{% if pilot_trust %}
  {% if badge_tone == 'new' %}
    {% assign sc_badge_label = 'Pilot preview' %}
    {% assign sc_badge_tone = 'preview' %}
  {% elsif badge_tone == 'preview' and badge_label != blank %}
    {% assign sc_badge_label = 'Pilot preview' %}
  {% endif %}
{% endif %}
{% assign sc_price_was = price_was %}
{% assign sc_price_save = price_save %}
{% if pilot_trust %}
  {% assign sc_price_was = blank %}
  {% assign sc_price_save = blank %}
{% endif %}

<div class="product-card product-card--static">
  <div class="prod-img">
    {% render 'decorative-image',
      src: image_src,
      alt: image_alt | default: 'Decorative product preview',
      width: image_width | default: 600,
      height: image_height | default: 600
    %}
    {% render 'product-badge', label: sc_badge_label, tone: sc_badge_tone %}
    <button
      class="p-wish"
      type="button"
      disabled
      aria-disabled="true"
      aria-label="Favourites paused. Save feature coming later during private preview."
    >
      <svg width="14" height="14" fill="none" stroke="#666" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
    </button>
  </div>
  <div class="prod-info">
    <div class="p-type">{{ product_type }}</div>
    <div class="p-name">{{ product_name }}</div>
    <div class="p-stars">{{ stars }} <span class="p-rev">{{ reviews }}</span></div>
    {% render 'price-stack', price_now: price_now, price_was: sc_price_was, price_save: sc_price_save %}
    <button
      class="add-btn add-btn--disabled"
      type="button"
      disabled
      aria-disabled="true"
      aria-label="{% if pilot_trust %}Invite-only pilot. Add to Cart is not available yet.{% else %}Preview only. Add to Cart is not available for this item yet.{% endif %}"
    >
      {% if pilot_trust %}Not available to buy yet{% else %}Preview only{% endif %}
    </button>
  </div>
</div>
