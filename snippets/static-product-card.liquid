<div class="product-card">
  <div class="prod-img">
    <img src="{{ image_src }}" alt="{{ image_alt }}" loading="lazy" width="{{ image_width | default: 600 }}" height="{{ image_height | default: 600 }}">
    {% render 'product-badge', label: badge_label, tone: badge_tone %}
    <button
      class="p-wish"
      type="button"
      disabled
      aria-disabled="true"
      aria-label="Wishlist coming soon. Favourites are not available yet."
    >
      <svg width="14" height="14" fill="none" stroke="#666" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
    </button>
  </div>
  <div class="prod-info">
    <div class="p-type">{{ product_type }}</div>
    <div class="p-name">{{ product_name }}</div>
    <div class="p-stars">{{ stars }} <span class="p-rev">{{ reviews }}</span></div>
    {% render 'price-stack', price_now: price_now, price_was: price_was, price_save: price_save %}
    <button class="add-btn" type="button">Add to Cart</button>
  </div>
</div>
