{% liquid
  assign preview_route_cautious = false
  assign controlled_preview_route_path = '/collections/controlled-pilot'
  assign controlled_preview_pageurl = blank
  if request.page_type == 'product' and product != blank
    for tag in product.tags
      assign nt = tag | downcase | strip | replace: ' ', '-'
      if nt == 'preview-only'
        assign preview_route_cautious = true
        break
      endif
    endfor
  elsif request.page_type == 'collection' and collection != blank
    for coll_product in collection.products limit: 48
      for tag in coll_product.tags
        assign nt = tag | downcase | strip | replace: ' ', '-'
        if nt == 'preview-only'
          assign preview_route_cautious = true
          break
        endif
      endfor
      if preview_route_cautious
        break
      endif
    endfor
  elsif request.path == controlled_preview_route_path or canonical_url contains controlled_preview_route_path
    assign preview_route_cautious = true
  elsif request.page_type == '404' and content_for_header contains '"pageurl":"'
    # theme-check-disable-next-line ContentForHeaderModification
    assign controlled_preview_pageurl = content_for_header | split: '"pageurl":"' | last | split: '"' | first | replace: '\\/', '/' | replace: '\\u0026', '&'
    if controlled_preview_pageurl contains controlled_preview_route_path
      assign preview_route_cautious = true
    endif
  endif
%}
{% if preview_route_cautious %}preview-route-cautious{% endif %}
